# Developer-machine runtime contract.
# Copy to .env and replace placeholders locally. Never commit live values.

HA_URL=http://homeassistant.example:8123
HA_TOKEN=<home_assistant_long_lived_access_token>
HA_SSH_KEY_PATH=<absolute_path_to_private_key>
HA_SSH_KNOWN_HOSTS=<absolute_path_to_verified_known_hosts>
HA_SSH_HOST_LAN=<user@lan-host-or-ip>
HA_SSH_HOST_TAILSCALE=<user@tailscale-host-or-ip>
HA_REMOTE_CONTAINER=homeassistant
HA_REMOTE_PATH=/config
